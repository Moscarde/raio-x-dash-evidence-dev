# Copie para .env (gitignored) e ajuste para seu ambiente local.
# Nomes seguem a convenção do Evidence: EVIDENCE_SOURCE__<nome_da_source>__<opcao>
# A source "raio_x_saude" é definida em sources/raio_x_saude/connection.yaml.
EVIDENCE_SOURCE__raio_x_saude__user=usuario_local
EVIDENCE_SOURCE__raio_x_saude__password=senha_local
